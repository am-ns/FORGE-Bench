{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FORGE-Bench Sample",
  "description": "Schema for each entry in dataset/annotations/samples.json",
  "type": "object",
  "required": [
    "task_id",
    "domain",
    "topology_type",
    "image_path",
    "prompt",
    "video_generation_prompt",
    "motion_type",
    "viewpoint_motion_target",
    "difficulty_profile",
    "constraint_annotations",
    "industrial_logic_questions",
    "sensitivity_variants"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z]{2,8}(_[a-z]+){0,2}_[0-9]{3}$|^S[A-Z][0-9]{2}$"
    },
    "domain": {
      "type": "string",
      "enum": [
        "visual_security",
        "embodied_robotics",
        "heavy_load_construction",
        "precision_defect_gen",
        "extreme_emergency"
      ]
    },
    "topology_type": {
      "type": "string",
      "enum": ["surface", "lattice", "kinematic", "flexible"]
    },
    "primary_topology": {
      "type": "string",
      "enum": ["surface", "lattice", "kinematic", "flexible"]
    },
    "sub_topology": {
      "type": "string",
      "enum": [
        "articulated",
        "rotational",
        "aerodynamic",
        "rigid_housing",
        "2d_planar",
        "3d_spatial",
        "cable_hose"
      ]
    },
    "image_path": {
      "type": "string",
      "pattern": "^dataset[\\\\/]images(_hq)?[\\\\/]"
    },
    "prompt": {
      "type": "string",
      "minLength": 50
    },
    "video_generation_prompt": {
      "type": "string",
      "description": "Direct prompt intended for image-to-video generation models.",
      "minLength": 50
    },
    "motion_type": {
      "type": "string",
      "enum": ["orbit", "pan", "crane", "dolly", "tilt", "static"]
    },
    "viewpoint_motion_target": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "string",
          "pattern": "^(orbit_(cw|ccw)_[0-9]+deg|crane_up_[0-9]+deg|horizontal_pan_lr|dolly_in_[0-9]+x)$"
        }
      ]
    },
    "difficulty_profile": {
      "type": "object",
      "description": "Per-axis difficulty classification for adversarial calibration.",
      "additionalProperties": {
        "type": "string",
        "enum": ["easy", "medium", "hard", "adversarial"]
      }
    },
    "constraint_annotations": {
      "type": "object",
      "additionalProperties": true
    },
    "task_category": {
      "type": "string",
      "enum": [
        "rigid_body_kinematics_and_coupling",
        "topology_mutation_and_failure",
        "fluid_dynamics_and_thermodynamics",
        "spatial_exploration_and_viewpoint",
        "industrial_logic_and_compliance"
      ]
    },
    "application_value": {
      "type": "string",
      "minLength": 20
    },
    "axis_weights": {
      "type": "object",
      "description": "Dynamic per-sample model-evaluation weights.",
      "additionalProperties": {
        "type": "number",
        "minimum": 0
      }
    },
    "axis_rubric": {
      "type": "object",
      "description": "Task-specific scoring criteria by axis.",
      "additionalProperties": {
        "type": "string",
        "minLength": 10
      }
    },
    "failure_target": {
      "type": "string"
    },
    "industrial_logic_questions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "text", "answer"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "answer": {
            "type": "string",
            "enum": ["yes", "no"]
          },
          "weakness_target": {
            "type": "string",
            "pattern": "^W[2-7]$"
          }
        },
        "additionalProperties": false
      }
    },
    "sensitivity_variants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "difficulty", "prompt_delta", "viewpoint_motion_target_delta"],
        "properties": {
          "id": { "type": "string" },
          "difficulty": { "type": "string" },
          "prompt_delta": { "type": "string" },
          "viewpoint_motion_target_delta": { "type": "number" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
