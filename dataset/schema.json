{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FORGE-Bench Sample",
  "description": "Schema for each entry in dataset/annotations/samples.json",
  "type": "object",
  "required": [
    "task_id",
    "domain",
    "topology_type",
    "image_path",
    "prompt",
    "vfa_target",
    "questions",
    "constraint_annotations"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z]{2,8}(_[a-z]+){0,2}_[0-9]{3}$|^S[A-Z][0-9]{2}$"
    },
    "domain": {
      "type": "string",
      "enum": [
        "aerospace",
        "electronics",
        "manufacturing",
        "energy_power",
        "energy_renewable",
        "oil_gas",
        "construction",
        "maritime",
        "chemical",
        "mining"
      ]
    },
    "topology_type": {
      "type": "string",
      "enum": [
        "surface",
        "lattice",
        "kinematic"
      ]
    },
    "failure_target": {
      "type": "string",
      "minLength": 10
    },
    "text": {
      "type": "string",
      "minLength": 20
    },
    "image_path": {
      "type": "string",
      "pattern": "^dataset/images/"
    },
    "vfa_target": {
      "type": "number"
    },
    "prompt": {
      "type": "string",
      "minLength": 50
    },
    "questions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "text", "answer", "weakness_target"],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "answer": {
            "type": "string",
            "enum": ["yes", "no"]
          },
          "weakness_target": {
            "type": "string",
            "pattern": "^W[2-7]$"
          }
        },
        "additionalProperties": false
      }
    },
    "constraint_annotations": {
      "type": "object",
      "required": ["topology_type"],
      "additionalProperties": true
    },
    "reverse": {
      "type": "boolean"
    },
    "extra_frame": {
      "type": "integer"
    },
    "difficulty_profile": {
      "type": "object",
      "description": "Per-axis difficulty classification for adversarial calibration.",
      "additionalProperties": {
        "type": "string",
        "enum": ["easy", "medium", "hard", "adversarial"]
      }
    }
  },
  "additionalProperties": true
}
